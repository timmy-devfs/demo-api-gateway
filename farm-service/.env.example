PORT=8082
NODE_ENV=development
DATABASE_URL="mongodb://localhost:27017/farm_db"
KAFKA_OPTIONAL="true"
KAFKA_BROKERS="localhost:9092"
KAFKA_CLIENT_ID="farm-service"
KAFKA_GROUP_ID="farm-service-consumer"
KAFKA_TOPIC_SEASON_CREATED="farm.season-created"
KAFKA_TOPIC_SEASON_UPDATED="farm.season-updated"
KAFKA_TOPIC_SEASON_EXPORTED="farm.season-exported"
KAFKA_TOPIC_ORDER_CONFIRMED="farm.order-confirmed"
REDIS_OPTIONAL="true"
REDIS_URL="redis://localhost:6379"